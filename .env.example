###############################################################################
# Paperless-NGX Konfiguration — Template / Beispiel
# Ablage: /opt/paperless/.env
#
# Dieses File ist das Beispiel/Template. Produktive Werte liegen in .env
# (nicht ins Git einchecken — enthält Secrets).
###############################################################################


# ─────────────────────────────────────────────────────────────────────────────
# PAPERLESS CORE
# ─────────────────────────────────────────────────────────────────────────────

# UID/GID des Paperless-Prozesses im Container — muss mit dem Host-User
# übereinstimmen der die Dateien besitzt (z.B. 1000/1000).
# Falsche Werte → Paperless kann Dateien nicht lesen/schreiben.
USERMAP_UID=1000
USERMAP_GID=1000

# Öffentliche URL von Paperless — wird für Links in Mails und SSO-Redirects verwendet.
# Muss mit PAPERLESS_CSRF_TRUSTED_ORIGINS übereinstimmen.
PAPERLESS_URL=https://paperless.example.com

# Interne URL für Container-zu-Container Kommunikation (ohne nginx/Authentik davor).
PAPERLESS_INTERNAL_URL=http://localhost:8000

# Geheimer Schlüssel für Django-Sessions und CSRF-Schutz.
# Zufällige Zeichenkette, min. 50 Zeichen. Niemals teilen oder publizieren.
# Generieren: python3 -c "import secrets; print(secrets.token_urlsafe(60))"
PAPERLESS_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_KEY_MIN_50_CHARS

PAPERLESS_TIME_ZONE=Europe/Zurich

# Komma-getrennte Liste erlaubter Origins für CSRF (muss PAPERLESS_URL enthalten).
PAPERLESS_CSRF_TRUSTED_ORIGINS=https://paperless.example.com

# URL zu der nach dem Logout weitergeleitet wird (z.B. Authentik Logout-Endpoint).
PAPERLESS_LOGOUT_REDIRECT_URL=https://auth.example.com/application/o/paperless/end-session/

# OCR-Sprachen (tessdata Kürzel, + getrennt).
# deu+eng reicht für Schweizer Haushalt, ggf. ita+fra ergänzen.
PAPERLESS_OCR_LANGUAGE=deu+eng

# Ablageort für Paperless-Daten (Datenbank, Indizes etc.) — muss persistentes Volume sein.
PAPERLESS_DATA_DIR=/mnt/paperless-data/data


# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTIK SSO
# ─────────────────────────────────────────────────────────────────────────────

# Aktiviert den OpenID Connect Provider (Authentik).
PAPERLESS_APPS=allauth.socialaccount.providers.openid_connect

# JSON-Konfiguration des OIDC-Providers.
# Enthält client_id, secret und die Discovery-URL von Authentik.
# Format: {"openid_connect": {"APPS": [{"provider_id": "...", "name": "...",
#   "client_id": "...", "secret": "...", "settings": {"server_url": "..."}}]}}
# Secret aus Authentik Provider-Einstellungen kopieren — niemals teilen.
PAPERLESS_SOCIALACCOUNT_PROVIDERS=REPLACE_WITH_JSON_FROM_AUTHENTIK

# Neuen SSO-Benutzer automatisch anlegen (kein manuelles Erstellen nötig).
PAPERLESS_SOCIAL_AUTO_SIGNUP=true

# Gruppen aus Authentik in Paperless synchronisieren.
PAPERLESS_SOCIAL_ACCOUNT_SYNC_GROUPS=true

# Standard-Gruppe für neue Benutzer.
PAPERLESS_DEFAULT_GROUP=family

# Optional: Nur SSO erlauben (lokaler Login deaktiviert):
#PAPERLESS_DISABLE_REGULAR_LOGIN=true
#PAPERLESS_REDIRECT_LOGIN_TO_SSO=true


# ─────────────────────────────────────────────────────────────────────────────
# API TOKEN
# (für post_consume.py + correspondent_manager_app.py)
# ─────────────────────────────────────────────────────────────────────────────

# Paperless API-Token eines Admin-Benutzers.
# In Paperless erstellen: Admin → Tokens → Token hinzufügen.
# Wird von post_consume.py (PAPERLESS_TOKEN) und
# correspondent_manager_app.py (PAPERLESS_API_TOKEN) gelesen —
# beide Variablen müssen denselben Wert haben.
PAPERLESS_TOKEN=REPLACE_WITH_PAPERLESS_API_TOKEN
PAPERLESS_API_TOKEN=REPLACE_WITH_PAPERLESS_API_TOKEN

# Interne API-URL (ohne nginx davor — direkt an den Paperless-Container).
PAPERLESS_API_URL=http://localhost:8000/api

# Pfad zur Document-Review-Queue (wird von post_consume + paper.manager geteilt).
DOCUMENT_REVIEW_QUEUE=/opt/paperless-scripts/training/document_review_queue.jsonl


# ─────────────────────────────────────────────────────────────────────────────
# CONSUMER / SCRIPTS
# ─────────────────────────────────────────────────────────────────────────────

# Pfade zu den Consume-Scripts (müssen ausführbar sein).
PAPERLESS_POST_CONSUME_SCRIPT=/opt/paperless-scripts/post_consume.py
PAPERLESS_PRE_CONSUME_SCRIPT=/opt/paperless-scripts/pre_consume.sh

# Polling-Intervall in Sekunden für neue Dateien im consume-Verzeichnis.
PAPERLESS_CONSUMER_POLLING=10

# Barcode-Erkennung für Trennseiten aktivieren.
PAPERLESS_CONSUMER_ENABLE_BARCODES=true

# Celery-Worker für parallele Verarbeitung.
# 2 Worker × 2 Threads = 4 parallele Tasks (anpassen je nach CPU).
PAPERLESS_TASK_WORKERS=2
PAPERLESS_THREADS_PER_WORKER=2


# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA / LLM-MODELLE
# ─────────────────────────────────────────────────────────────────────────────

# URL des Ollama-Servers (GMKtec EVO, AMD Ryzen AI Max+ 395, 128GB RAM).
# Muss vom Paperless-Container erreichbar sein.
OLLAMA_BASE_URL=http://IP_ADRESSE_OLLAMA_SERVER:11434

# Vision-Modell: analysiert Dokument-Bild → extrahiert Absender, Datum,
# Betrag, Kennzeichen, handschriftliche Notizen (bez. 6.2.26 → Bezahlt).
OLLAMA_MODEL_VISION=qwen2.5vl:7b
# Alternativ (höhere Qualität, langsamer):
#OLLAMA_MODEL_VISION=qwen2.5vl:32b

# Reasoning-Modell: klassifiziert Dokumenttyp, Tags, Ordner.
OLLAMA_MODEL_LLM=llama3.3:70b
# Alternativ (schneller, weniger präzise):
#OLLAMA_MODEL_LLM=llama3:8b

# Wird vom correspondent_manager gelesen (muss mit OLLAMA_MODEL_LLM übereinstimmen).
OLLAMA_MODEL=llama3.3:70b

# Modell für schwierige Grenzfälle (Eskalation nach Batch-Ende).
OLLAMA_MODEL_ESCALATION=llama3.3:70b

# Timeouts in Sekunden — gross genug für 70B Modell auf GPU.
VISION_TIMEOUT=600
LLM_TIMEOUT=600


# ─────────────────────────────────────────────────────────────────────────────
# STORAGE / PIPELINE
# ─────────────────────────────────────────────────────────────────────────────

# api  = Speicherpfad via Paperless API setzen (Standard, empfohlen)
# copy = shutil.copy2() direkt nach documents_sorted/ (Fallback ohne API)
PAPERLESS_STORAGE_MODE=api

# Maximale Anzahl Trainings-Samples pro Ordner (0 = deaktiviert).
SAMPLE_MAX_PER_FOLDER=10


# ─────────────────────────────────────────────────────────────────────────────
# ESKALATION
# ─────────────────────────────────────────────────────────────────────────────

# Queue für Dokumente die manuellen Review benötigen.
ESCALATION_QUEUE=/opt/paperless-scripts/training/escalation_queue.jsonl


# ─────────────────────────────────────────────────────────────────────────────
# KORRESPONDENTEN-KANONISIERUNG
# (genutzt von post_consume.py UND correspondent_manager_app.py)
# ─────────────────────────────────────────────────────────────────────────────

# Pfad zur Korrespondenten-Map (bekannte Absender).
CORRESPONDENTS_JSON=/opt/paperless-scripts/training/correspondents.json

# Queue für neue (unbekannte) Korrespondenten — paper.manager liest diese.
PENDING_JSONL=/opt/paperless-scripts/training/pending_correspondents.jsonl

# Tag-Name für Dokumente die manuellen Review benötigen.
PENDING_REVIEW_TAG=pending_review

# Fuzzy-Match Schwellenwerte für Korrespondenten-Erkennung:
#   >= HIGH_THRESHOLD  → "ergaenzung" (sehr ähnlich, wahrscheinlich Schreibvariante)
#   >= MERGE_THRESHOLD → "merge_into" (ähnlich, möglicher Merge-Kandidat)
#   <  MERGE_THRESHOLD → "neu"        (unbekannter Korrespondent → Review-Queue)
HIGH_THRESHOLD=90
MERGE_THRESHOLD=70

# Paperless-Gruppen die auf alle Dokumente Lesezugriff haben.
PAPERLESS_VIEW_GROUPS=family,Eltern

# Paperless-Gruppen die auf alle Dokumente Schreibzugriff haben.
PAPERLESS_CHANGE_GROUPS=Eltern

# Paperless User-ID des Besitzers neuer Objekte (Korrespondenten, Tags etc.).
# In Paperless nachschauen: Admin → Benutzer → ID in der URL.
PAPERLESS_OWNER_ID=REPLACE_WITH_OWNER_USER_ID

# Gruppen-IDs (numerisch) für Berechtigungen — müssen mit den Gruppen-IDs
# in Paperless übereinstimmen (Admin → Gruppen → ID in der URL).
# z.B. 1,2 (IDs aus Paperless Admin → Gruppen → ID in der URL)
PAPERLESS_VIEW_GROUP_IDS=REPLACE_WITH_VIEW_GROUP_IDS
# z.B. 2 (ID aus Paperless Admin → Gruppen → ID in der URL)
PAPERLESS_CHANGE_GROUP_IDS=REPLACE_WITH_CHANGE_GROUP_ID

# Pfad zum Audit-Log (alle Pipeline-Aktionen).
AUDIT_LOG_PATH=/opt/paperless-scripts/training/audit_log.jsonl

# Optionaler Token für den paper.manager API-Zugriff ohne Browser-Session.
# Schützt direkte API-Aufrufe falls kein Authentik/nginx davor.
# Generieren: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Leer lassen = nur Reverse-Proxy-Schutz (kein zusätzlicher Token-Check).
PAPER_MANAGER_TOKEN=REPLACE_WITH_RANDOM_TOKEN_OR_LEAVE_EMPTY


# ─────────────────────────────────────────────────────────────────────────────
# CUSTOM FIELDS (Paperless)
# IDs nachschauen: Paperless Admin → Custom Fields → ID in der URL
# ─────────────────────────────────────────────────────────────────────────────

# CHF — Rechnungsbetrag (Monetär), aus QR-Bill
CF_BETRAG_ID=1
# Rechnungsnummer (Text), aus QR-Bill / Vision
CF_RECHNUNGSNUMMER_ID=5
# Kundennummer (Text), aus Vision
CF_KUNDENNUMMER_ID=6
# QR-Referenz (Text), aus QR-Bill
CF_QR_REFERENZ_ID=7
# Fällig am (Datum), aus QR-Bill
CF_FAELLIG_AM_ID=8
# Status (Auswahl: Offen/Bezahlt), automatisch gesetzt
CF_STATUS_ID=9
# Policennummer (Text), aus Vision bei Versicherungen
CF_POLICENNUMMER_ID=10
# Auto-Kennzeichen (Auswahl: XX 000001 etc.), aus Vision
CF_KENNZEICHEN_ID=11
# Bezahlt am (Datum), aus Handschrift "bez. 6.2.26"
CF_BEZAHLT_AM_ID=12
# Gescannt am (Datum), immer = heute (Scan-Datum)
CF_GESCANNT_AM_ID=13


# ─────────────────────────────────────────────────────────────────────────────
# PIPELINE-MODUS
# ─────────────────────────────────────────────────────────────────────────────

# QS-Modus: always = alle Dokumente in Review, uncertain = nur unsichere, never = kein Review
# Wird über paper.manager UI gesetzt — hier nur Default beim ersten Start.
PENDING_MODE=uncertain

# Komma-getrennte Python-Regex für Tags die Confidence NICHT senken.
# Jahreszahlen und Monat.Jahr werden standardmässig ignoriert.
# Standard (bereits Default — nur überschreiben wenn nötig):
#CONFIDENCE_IGNORE_TAG_PATTERNS=^\d{4}$,^\d{1,2}\.\d{4}$

# Nur Jahreszahlen ignorieren:
#CONFIDENCE_IGNORE_TAG_PATTERNS=^\d{4}$

# Jahreszahlen + Monatsnamen (deutsch):
#CONFIDENCE_IGNORE_TAG_PATTERNS=^\d{4}$,^(Januar|Februar|März|April|Mai|Juni|Juli|August|September|Oktober|November|Dezember)$

# Alles oben + 2-stellige Jahreszahlen (z.B. "25"):
#CONFIDENCE_IGNORE_TAG_PATTERNS=^\d{4}$,^\d{2}$,^\d{1,2}\.\d{4}$

# Nichts ignorieren (jeder verworfene Tag senkt Confidence):
#CONFIDENCE_IGNORE_TAG_PATTERNS=

# Dateiname-Format für Paperless Storage.
PAPERLESS_FILENAME_FORMAT={correspondent}/{document_type}/{created_year}/{title}

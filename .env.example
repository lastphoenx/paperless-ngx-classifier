###############################################################################
# Paperless-NGX — Template / Beispiel
# Produktiv: /opt/paperless/.env (nicht ins Git — enthält Secrets)
###############################################################################


# ─────────────────────────────────────────────────────────────────────────────
# PAPERLESS CORE
# ─────────────────────────────────────────────────────────────────────────────

# UID/GID des Paperless-Prozesses im Container — muss mit Host-Dateibesitzer übereinstimmen.
USERMAP_UID=1000
USERMAP_GID=1000

# Öffentliche URL — Links, SSO-Redirects; muss in PAPERLESS_CSRF_TRUSTED_ORIGINS stehen.
PAPERLESS_URL=https://paperless.example.com

# Interne URL Container-zu-Container (ohne Reverse-Proxy).
PAPERLESS_INTERNAL_URL=http://localhost:8000

# Django Secret — min. 50 Zeichen, zufällig generieren, niemals teilen.
# python3 -c "import secrets; print(secrets.token_urlsafe(60))"
PAPERLESS_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_KEY_MIN_50_CHARS

PAPERLESS_TIME_ZONE=Europe/Zurich

# CSRF — muss PAPERLESS_URL entsprechen.
PAPERLESS_CSRF_TRUSTED_ORIGINS=https://paperless.example.com

# Redirect nach Logout (z. B. IdP End-Session).
PAPERLESS_LOGOUT_REDIRECT_URL=https://auth.example.com/application/o/paperless/end-session/

# Persistentes Datenverzeichnis (DB, Indizes).
PAPERLESS_DATA_DIR=/mnt/paperless-data/data

# Dateiname in Paperless Storage.
PAPERLESS_FILENAME_FORMAT={correspondent}/{document_type}/{created_year}/{title}


# ─────────────────────────────────────────────────────────────────────────────
# OCR
# ─────────────────────────────────────────────────────────────────────────────

# Tessdata-Sprachen (+ getrennt).
PAPERLESS_OCR_LANGUAGE=deu+eng

# skip = vorhandene Textschicht nutzen (Legacy-Altbestand)
# redo = immer OCR (neue Scans)
PAPERLESS_OCR_MODE=skip


# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTIK / SSO
# ─────────────────────────────────────────────────────────────────────────────

PAPERLESS_APPS=allauth.socialaccount.providers.openid_connect

# JSON aus Authentik Provider — client_id, secret, server_url.
PAPERLESS_SOCIALACCOUNT_PROVIDERS=REPLACE_WITH_JSON_FROM_AUTHENTIK

PAPERLESS_SOCIAL_AUTO_SIGNUP=true
PAPERLESS_SOCIAL_ACCOUNT_SYNC_GROUPS=true
PAPERLESS_DEFAULT_GROUP=family

# Optional: nur SSO, kein lokaler Login
#PAPERLESS_DISABLE_REGULAR_LOGIN=true
#PAPERLESS_REDIRECT_LOGIN_TO_SSO=true


# ─────────────────────────────────────────────────────────────────────────────
# API TOKEN
# ─────────────────────────────────────────────────────────────────────────────

# Admin → Tokens — gleicher Wert für beide Variablen.
PAPERLESS_TOKEN=REPLACE_WITH_PAPERLESS_API_TOKEN
PAPERLESS_API_TOKEN=REPLACE_WITH_PAPERLESS_API_TOKEN

PAPERLESS_API_URL=http://localhost:8000/api

DOCUMENT_REVIEW_QUEUE=/opt/paperless-scripts/training/document_review_queue.jsonl

# Optional: API-Schutz paper.manager ohne Browser-Session.
# Leer = nur Reverse-Proxy-Schutz.
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PAPER_MANAGER_TOKEN=REPLACE_WITH_RANDOM_TOKEN_OR_LEAVE_EMPTY


# ─────────────────────────────────────────────────────────────────────────────
# CONSUMER / SCRIPTS
# ─────────────────────────────────────────────────────────────────────────────

PAPERLESS_POST_CONSUME_SCRIPT=/opt/paperless-scripts/post_consume.py
PAPERLESS_PRE_CONSUME_SCRIPT=/opt/paperless-scripts/pre_consume.sh

PAPERLESS_CONSUMER_POLLING=10
PAPERLESS_CONSUMER_ENABLE_BARCODES=true

# Rekursiv — Pflicht für consume/legacy/<batch>/
PAPERLESS_CONSUMER_RECURSIVE=true

# Eigenen ML-Classifier nicht trainieren (eigene Skripte).
PAPERLESS_TRAIN_TASK_CRON=disable

# 1 Worker — verhindert Races bei parallelem Upload + post_consume.
PAPERLESS_TASK_WORKERS=1
PAPERLESS_THREADS_PER_WORKER=2

# Legacy: Pfade mit diesen Teilstrings → pre/post_consume überspringen.
LEGACY_CONSUME_MARKERS=/legacy/
LEGACY_TAG=legacy

# Nur Tag legacy (kein legacy-<batch> pro Ordner)
LEGACY_SET_BATCH_TAG=false

# Speicherpfad unter originals/legacy/ — Name muss in Paperless existieren oder wird angelegt
LEGACY_STORAGE_PATH_NAME=Legacy
LEGACY_STORAGE_PATH_TEMPLATE=legacy/{title}

# Host-Pfade für legacy-import-batch.sh (nicht Container) — siehe docs/LEGACY_IMPORT.md
LEGACY_CONSUME_ROOT=/mnt/paperless-data/consume/legacy
# QR-Split aus Paperless-Dok → volle Pipeline (nicht legacy/)
PAPERLESS_CONSUME_DIR=/mnt/paperless-data/consume
LEGACY_SPLIT_QR_REGEX=^[0-9]{6}_[^\s]+$
BRILLENPASS_DEDUP_DAYS=21
LEGACY_NAS_ROOT=/mnt/nas-legacy


# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA / LLM
# ─────────────────────────────────────────────────────────────────────────────

# Vom Paperless-Container erreichbar.
OLLAMA_BASE_URL=http://ollama.example.com:11434

OLLAMA_MODEL_VISION=qwen2.5vl:7b
#OLLAMA_MODEL_VISION=qwen2.5vl:32b

OLLAMA_MODEL_LLM=llama3.3:70b
#OLLAMA_MODEL_LLM=llama3:8b

# correspondent_manager — muss mit OLLAMA_MODEL_LLM übereinstimmen.
OLLAMA_MODEL=llama3.3:70b

OLLAMA_MODEL_ESCALATION=llama3.3:70b

VISION_TIMEOUT=600
LLM_TIMEOUT=600


# ─────────────────────────────────────────────────────────────────────────────
# STORAGE / PIPELINE
# ─────────────────────────────────────────────────────────────────────────────

# api = Speicherpfad via Paperless API (Standard)
# copy = shutil.copy2 Fallback
PAPERLESS_STORAGE_MODE=api

SAMPLE_MAX_PER_FOLDER=10

ESCALATION_QUEUE=/opt/paperless-scripts/training/escalation_queue.jsonl


# ─────────────────────────────────────────────────────────────────────────────
# KORRESPONDENTEN / REVIEW
# ─────────────────────────────────────────────────────────────────────────────

CORRESPONDENTS_JSON=/opt/paperless-scripts/training/correspondents.json
PENDING_JSONL=/opt/paperless-scripts/training/pending_correspondents.jsonl
PENDING_REVIEW_TAG=pending_review

HIGH_THRESHOLD=90
MERGE_THRESHOLD=70

PAPERLESS_VIEW_GROUPS=family,Eltern
PAPERLESS_CHANGE_GROUPS=Eltern

# Numerische Gruppen-IDs aus Paperless Admin → Gruppen → URL.
PAPERLESS_VIEW_GROUP_IDS=REPLACE_WITH_VIEW_GROUP_IDS
PAPERLESS_CHANGE_GROUP_IDS=REPLACE_WITH_CHANGE_GROUP_ID

# Optional — owner=null, nur Gruppen-Permissions (empfohlen).
#PAPERLESS_OWNER_ID=REPLACE_WITH_OWNER_USER_ID

AUDIT_LOG_PATH=/opt/paperless-scripts/training/audit_log.jsonl

# always | uncertain | never
PENDING_MODE=uncertain

# Tags die Confidence nicht senken (Regex, kommagetrennt).
# Standard wenn weggelassen: ^\d{4}$,^\d{1,2}\.\d{4}$
#CONFIDENCE_IGNORE_TAG_PATTERNS=^\d{4}$


# ─────────────────────────────────────────────────────────────────────────────
# CUSTOM FIELDS (IDs aus Paperless Admin → Custom Fields → URL)
# ─────────────────────────────────────────────────────────────────────────────

# Betrag (CHF)
CF_BETRAG_ID=1
# Rechnungsnummer
CF_RECHNUNGSNUMMER_ID=5
# Kundennummer
CF_KUNDENNUMMER_ID=6
# QR-Referenz
CF_QR_REFERENZ_ID=7
# Fällig am
CF_FAELLIG_AM_ID=8
# Status (Offen/Bezahlt)
CF_STATUS_ID=9
# Policennummer
CF_POLICENNUMMER_ID=10
# Kennzeichen
CF_KENNZEICHEN_ID=11
# Bezahlt am
CF_BEZAHLT_AM_ID=12
# Gescannt am
CF_GESCANNT_AM_ID=13
# Verarbeitung (auto STP)
CF_VERARBEITUNG_ID=14
# Person
CF_PERSON_ID=15
# Dok-ID — Paperless Custom Field (Typ: Zahl), bei jedem Pipeline-Lauf gesetzt
CF_DOK_ID=16
# Steuerjahr — Integer, gesetzt wenn Tag Steuerrelevant
CF_STEUERJAHR_ID=17
STEUERRELEVANT_TAG=Steuerrelevant


# ─────────────────────────────────────────────────────────────────────────────
# BRILLENPASS
# ─────────────────────────────────────────────────────────────────────────────

BRILLENPAESSE_JSON=/opt/paperless-scripts/training/brillenpaesse.json
PENDING_BRILLENPASS_JSONL=/opt/paperless-scripts/training/pending_brillenpass.jsonl
PENDING_BRILLENPASS_TAG=pending_brillenpass


# ─────────────────────────────────────────────────────────────────────────────
# PAPERLESS v3 (nur bei Upgrade auf 3.0.0 stable — siehe docs/UPGRADE_V3.md)
# ─────────────────────────────────────────────────────────────────────────────
# Bis dahin v2-Variablen oben verwenden. Nicht mischen!
#
# PAPERLESS_OCR_MODE=auto
# PAPERLESS_ARCHIVE_FILE_GENERATION=auto
# PAPERLESS_CONSUMER_POLLING_INTERVAL=10
# PAPERLESS_CONSUMER_DELETE_DUPLICATES=true
# In docker-compose.yml zusätzlich:
#   PAPERLESS_DBENGINE=postgresql
#   image: ghcr.io/paperless-ngx/paperless-ngx:3.0.0
